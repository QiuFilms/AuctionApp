{
    "swagger": "2.0",
    "info": {
        "description": "API serwera Go (BFF) dla systemu aukcyjnego.",
        "title": "Arcane Market API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/api/auctions": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Zwraca listę wszystkich dostępnych aukcji",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Auctions"
                ],
                "summary": "Lista aukcji",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/pb.AuctionListResponse"
                        }
                    }
                }
            }
        },
        "/api/avatar/download": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Pobiera plik avatara użytkownika",
                "produces": [
                    "image/png"
                ],
                "tags": [
                    "Avatar"
                ],
                "summary": "Pobierz avatar",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "file"
                        }
                    }
                }
            }
        },
        "/api/avatar/upload": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Wgrywa plik graficzny jako avatar użytkownika",
                "consumes": [
                    "multipart/form-data"
                ],
                "tags": [
                    "Avatar"
                ],
                "summary": "Prześlij avatar",
                "parameters": [
                    {
                        "type": "file",
                        "description": "Plik avatara (png, jpeg, gif)",
                        "name": "avatar",
                        "in": "formData",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/pb.UploadAvatarResponse"
                        }
                    }
                }
            }
        },
        "/api/inventory": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Zwraca listę przedmiotów w ekwipunku użytkownika",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Inventory"
                ],
                "summary": "Pobierz ekwipunek",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/pb.InventoryResponse"
                        }
                    }
                }
            }
        },
        "/api/items": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Pobiera katalog wszystkich dostępnych przedmiotów",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Items"
                ],
                "summary": "Lista przedmiotów",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/pb.InventoryResponse"
                        }
                    }
                }
            }
        },
        "/api/items/add": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Dodaje przedmiot do ekwipunku użytkownika",
                "consumes": [
                    "application/json"
                ],
                "tags": [
                    "Items"
                ],
                "summary": "Dodaj przedmiot",
                "parameters": [
                    {
                        "description": "ID przedmiotu",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "type": "object",
                            "properties": {
                                "itemId": {
                                    "type": "integer",
                                    "format": "int64"
                                }
                            }
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/pb.ActionResponse"
                        }
                    }
                }
            }
        },
        "/api/items/delete": {
            "delete": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Usuwa przedmiot z ekwipunku użytkownika",
                "tags": [
                    "Items"
                ],
                "summary": "Usuń przedmiot",
                "parameters": [
                    {
                        "type": "integer",
                        "format": "int64",
                        "description": "ID przedmiotu do usunięcia",
                        "name": "itemId",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/pb.ActionResponse"
                        }
                    }
                }
            }
        },
        "/api/login": {
            "post": {
                "description": "Weryfikuje dane użytkownika i zwraca token JWT",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Auth"
                ],
                "summary": "Logowanie użytkownika",
                "parameters": [
                    {
                        "description": "Dane logowania (username i password)",
                        "name": "credentials",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_handlers.LoginPayload"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Zwraca obiekt z polem 'token'",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "400": {
                        "description": "Błędne dane wejściowe",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Błąd wewnętrzny serwera",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/stats": {
            "get": {
                "description": "Zwraca zestawienie liczby wywołań poszczególnych endpointów z podziałem na statusy HTTP",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Stats"
                ],
                "summary": "Pobierz statystyki użycia endpointów",
                "responses": {
                    "200": {
                        "description": "Lista statystyk",
                        "schema": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "additionalProperties": true
                            }
                        }
                    },
                    "500": {
                        "description": "Błąd pobierania statystyk",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "internal_handlers.LoginPayload": {
            "type": "object",
            "properties": {
                "password": {
                    "type": "string"
                },
                "username": {
                    "type": "string"
                }
            }
        },
        "mmo-auctions-go_internal_handlers.LoginPayload": {
            "type": "object",
            "properties": {
                "password": {
                    "type": "string"
                },
                "username": {
                    "type": "string"
                }
            }
        },
        "pb.ActionResponse": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string"
                },
                "success": {
                    "type": "boolean"
                }
            }
        },
        "pb.AuctionListResponse": {
            "type": "object",
            "properties": {
                "active_auctions": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "pb.InventoryResponse": {
            "type": "object",
            "properties": {
                "items": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "pb.UploadAvatarResponse": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string"
                },
                "success": {
                    "type": "boolean"
                }
            }
        }
    },
    "securityDefinitions": {
        "BearerAuth": {
            "description": "Wpisz \"Bearer {twój_token}\" w pole poniżej.",
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}